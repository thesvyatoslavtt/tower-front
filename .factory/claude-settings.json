{
  "_comment": "Headless Claude Code settings the orchestrator copies into ~/.claude/settings.json inside the VM. Do not use locally — use .claude/settings.json for that. defaultMode=bypassPermissions trusts the agent because the VM is ephemeral and network/secrets are restricted at the infra layer.",
  "permissions": {
    "defaultMode": "bypassPermissions",
    "deny": [
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git push * main*)",
      "Bash(git push * master*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -fd*)",
      "Bash(git branch -D*)",
      "Bash(git commit --amend*)",
      "Bash(git rebase -i*)",
      "Bash(git config*)",
      "Bash(yarn publish*)",
      "Bash(npm publish*)",
      "Bash(npm install -g*)",
      "Bash(yarn global*)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~*)",
      "Bash(rm -rf .git*)",
      "Bash(rm -rf .factory*)",
      "Bash(rm -rf .github*)",
      "Bash(curl * | sh*)",
      "Bash(curl * | bash*)",
      "Bash(wget * | sh*)",
      "Bash(sudo*)",
      "Bash(chmod 777*)",
      "Bash(ssh*)",
      "Bash(scp*)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(~/.gnupg/**)",
      "Read(/etc/**)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Edit(**/.env)",
      "Edit(**/.env.*)",
      "Write(**/.env)",
      "Write(**/.env.*)",
      "Edit(.factory/**)",
      "Edit(.github/**)",
      "Edit(yarn.lock)",
      "Edit(package.json)",
      "Write(.factory/**)",
      "Write(.github/**)"
    ]
  },
  "env": {
    "CI": "true",
    "FORCE_COLOR": "0",
    "GIT_TERMINAL_PROMPT": "0",
    "HUSKY": "0",
    "npm_config_yes": "true"
  }
}
